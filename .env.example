APP_NAME="Event Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local development defaults to SQLite. Production should use MySQL (generated
# columns for §50) or PostgreSQL (partial unique indexes for §50).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=event_platform
# DB_USERNAME=root
# DB_PASSWORD=
# DB_ENGINE=mysql

# AUTH_TOKEN_NAME=api
# FRONTEND_RESET_PASSWORD_URL="${APP_URL}/reset-password"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Production: prefer Redis for tenant/subdomain caching (v1.0 §2, v1.3 §53)
# CACHE_STORE=redis
# CACHE_PREFIX=event_platform_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Platform queue names (IMPLEMENTATION_ROADMAP Phase 1)
QUEUE_NAME_DEFAULT=default
QUEUE_NAME_OUTBOX=outbox
QUEUE_NAME_NOTIFICATIONS=notifications

# Tenancy cache TTL (seconds)
TENANCY_BASE_DOMAIN=localhost
TENANCY_SUBDOMAIN_CACHE_TTL=3600
TENANCY_API_CLIENT_CACHE_TTL=3600
TENANCY_CACHE_PREFIX=tenant
TENANCY_API_KEY_HEADER=X-Api-Key
TENANCY_API_SECRET_HEADER=X-Api-Secret

# Payment gateways (Phase 7.2)
PAYMENT_GATEWAY_CONNECT_TIMEOUT=5
PAYMENT_GATEWAY_REQUEST_TIMEOUT=30
PAYMENT_GATEWAY_RETRY_ATTEMPTS=2
PAYMENT_GATEWAY_RETRY_DELAY_MS=250
SHAMCASH_BASE_URL=https://api.shamcash.example
SHAMCASH_API_KEY=
SHAMCASH_WEBHOOK_SECRET=
SHAMCASH_SIGNATURE_HEADER=X-ShamCash-Signature
SYRIATEL_CASH_BASE_URL=https://api.syriatelcash.example
SYRIATEL_CASH_API_KEY=
SYRIATEL_CASH_WEBHOOK_SECRET=
SYRIATEL_CASH_SIGNATURE_HEADER=X-Syriatel-Signature
